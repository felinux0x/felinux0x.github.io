---
import Layout from "../layouts/Layout.astro";
---

<Layout title="System Access — Restricted Area">
  <div class="min-h-screen w-full flex flex-col items-center justify-center p-4 sm:p-8 bg-black relative overflow-hidden font-mono text-white selection:bg-green-400 selection:text-black">
    
    <!-- Scanlines -->
    <div class="pointer-events-none fixed inset-0 z-20 opacity-[0.04] bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,1)_2px,rgba(0,0,0,1)_4px)]"></div>
    <!-- Vignette -->
    <div class="pointer-events-none fixed inset-0 z-10 bg-[radial-gradient(ellipse_at_center,transparent_40%,rgba(0,0,0,0.85)_100%)]"></div>
    <!-- Flicker overlay -->
    <div class="pointer-events-none fixed inset-0 z-30 opacity-0" id="flicker-overlay" style="background:rgba(0,255,70,0.02)"></div>

    <div class="z-40 w-full max-w-2xl flex flex-col gap-4">

      <!-- Top bar -->
      <div class="flex items-center justify-between text-[10px] text-green-500/40 tracking-widest uppercase px-1">
        <span id="clock">--:--:--</span>
        <span>SESSION_ID: <span class="text-green-500/60" id="session-id">----</span></span>
        <span>UPTIME: <span id="uptime">0s</span></span>
      </div>

      <!-- Terminal Window -->
      <div class="border border-green-500/20 bg-black rounded-lg shadow-[0_0_40px_rgba(0,255,70,0.05)] overflow-hidden">
        
        <!-- Title bar -->
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-green-500/10 bg-green-500/[0.03]">
          <div class="w-3 h-3 rounded-full bg-red-500/70 hover:bg-red-500 transition-colors cursor-pointer"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/70 hover:bg-yellow-500 transition-colors cursor-pointer"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/70 hover:bg-green-500 transition-colors cursor-pointer"></div>
          <span class="ml-3 text-[11px] font-bold text-green-500/40 tracking-[0.2em] uppercase">root@system:~ — bash</span>
        </div>
        
        <!-- Terminal Body -->
        <div class="p-5 sm:p-7 text-sm leading-relaxed h-[420px] flex flex-col">
          
          <div id="terminal-output" class="flex-1 overflow-y-auto space-y-2 mb-4 pr-1 scrollbar-thin">
            <p class="text-green-400 font-bold tracking-wide">Iniciando protocolo de segurança avançada...</p>
            <p class="text-green-500/50">[OK] Camada de ofuscação ativa.</p>
            <p class="text-green-500/50">[OK] Módulos de detecção passiva rodando em background.</p>
            <p class="text-green-500/50">[OK] Criptografia de sessão estabelecida.</p>
            <br/>
            <p class="text-green-400 font-bold tracking-[0.15em]">&gt;&gt; ACESSO RESTRITO &lt;&lt;</p>
            <p class="text-green-200/70">Apenas operadores autorizados podem prosseguir.</p>
            <br/>
            <p class="text-green-500/40 text-xs">Para provar seu nível de autorização, resolva os desafios abaixo.</p>
            <br/>
            <div id="challenge-container" class="p-4 border border-green-500/20 bg-green-500/[0.03] rounded">
              <p class="text-green-400/70 text-xs tracking-widest uppercase mb-2" id="challenge-prefix">Desafio Nível 1:</p>
              <p id="challenge-text" class="text-green-200/90 font-normal leading-relaxed"></p>
              <button id="btn-hint" type="button" class="mt-3 text-[10px] px-3 py-1 bg-black/60 border border-green-500/20 text-green-500/40 hover:text-green-400 hover:border-green-500/50 rounded transition-all tracking-widest uppercase">
                [ Mostrar Dica ]
              </button>
            </div>
          </div>

          <!-- Input -->
          <div class="flex items-center gap-3 pt-4 border-t border-green-500/10">
            <span class="text-green-400 font-bold text-xs tracking-wide shrink-0">root@system:~$</span>
            <input 
              type="text" 
              id="flag-input" 
              class="flex-1 bg-transparent border-none outline-none text-green-200/90 placeholder-green-500/20 font-mono caret-green-400 text-sm"
              placeholder="Digite a resposta e pressione ENTER..."
              autocomplete="off"
              spellcheck="false"
            />
          </div>

        </div>
      </div>

      <!-- Bottom bar -->
      <div class="flex items-center justify-between text-[10px] text-green-500/25 tracking-widest uppercase px-1">
        <span>ENCRYPTED</span>
        <span id="progress-text">NÍVEL 1/4</span>
        <span>v2.4.1</span>
      </div>

    </div>
  </div>
</Layout>

<script>
// @ts-nocheck
document.addEventListener('DOMContentLoaded', () => {

  // ── UI refs ──────────────────────────────────────────────────────────────
  const input       = document.getElementById('flag-input');
  const output      = document.getElementById('terminal-output');
  const challengePfx = document.getElementById('challenge-prefix');
  const challengeTxt = document.getElementById('challenge-text');
  const btnHint     = document.getElementById('btn-hint');
  const progressTxt = document.getElementById('progress-text');

  // ── Clock / uptime ───────────────────────────────────────────────────────
  const clockEl   = document.getElementById('clock');
  const uptimeEl  = document.getElementById('uptime');
  const sessionEl = document.getElementById('session-id');
  sessionEl.textContent = Math.random().toString(36).slice(2,10).toUpperCase();
  let uptimeSec = 0;
  setInterval(() => {
    const now = new Date();
    clockEl.textContent = now.toTimeString().slice(0,8);
    uptimeSec++;
    uptimeEl.textContent = uptimeSec < 60 ? `${uptimeSec}s` : `${Math.floor(uptimeSec/60)}m${uptimeSec%60}s`;
  }, 1000);

  // ── Subtle flicker ───────────────────────────────────────────────────────
  const flickerEl = document.getElementById('flicker-overlay');
  setInterval(() => {
    if (Math.random() < 0.08) {
      flickerEl.style.opacity = '1';
      setTimeout(() => flickerEl.style.opacity = '0', 60 + Math.random()*80);
    }
  }, 2000);

  // ── Obfuscation helpers ──────────────────────────────────────────────────
  // Destination is split + encoded so DevTools won't reveal it plainly
  const _d = [
    'aHR0cHM6Ly9qdW5pcGVyLXRyaWFuZ2xl',
    'LTNmNS5ub3Rpb24uc2l0ZS9QYXJhLWEt',
    'bWVuaW5hLWRvcy1vbGhvcy12ZXJkZXMt',
    'MzFjYjFiYWY2N2RjODBiYjg0MzZkMWRk',
    'ODEyZDQwNTU/cHZzPTc0'
  ];
  const getUrl = () => atob(_d.join(''));

  // Answers are hashed (djb2) — answers never appear in plain text
  const hash = s => [...s].reduce((h,c) => Math.imul(31,h)+c.charCodeAt(0)|0, 5381) >>> 0;

  // ── Desafios ─────────────────────────────────────────────────────────────
  const questions = [
    {
      text: "Qual é o nome do sistema operacional de código aberto cujo mascote é um pinguim chamado Tux?",
      hashes: [hash("linux")],
      hint: "Começa com 'L', termina com 'x'. Criado por Linus Torvalds."
    },
    {
      text: "Que linguagem de programação é a base da interatividade na web e roda nativamente nos navegadores?",
      hashes: [hash("javascript"), hash("js")],
      hint: "Sua sigla é frequentemente abreviada como JS."
    },
    {
      text: "Qual é a linguagem de marcação (sigla de 4 letras) usada para estruturar páginas web?",
      hashes: [hash("html")],
      hint: "Começa com H e termina com L."
    },
    {
      text: "Qual é o comando padrão do terminal Linux para listar os arquivos de um diretório?",
      hashes: [hash("ls")],
      hint: "Duas letras — abreviação de 'list'."
    }
  ];

  // ── Carta (armazenada ofuscada — base64 por parágrafo) ───────────────────
  const _letter = [
    btoa(encodeURIComponent("Bru, se você chegou até aqui, já viu que eu guardo muita coisa, né? Mas tem um sentimento que não cabe em desafio de terminal, nem em nenhuma lógica que eu conheça.")),
    btoa(encodeURIComponent("Eu queria que você soubesse o tamanho do orgulho que eu sinto de você. Olhar o seu esforço, te ver mergulhada nas matérias de ADS, aproveitando cada curso da Alura e com essa vontade absurda de fazer as coisas acontecerem... isso me ganha de um jeito difícil de explicar. Você me inspira, de verdade. Ver a sua garra pra crescer me dá vontade de ser alguém melhor também.")),
    btoa(encodeURIComponent("A gente brinca sobre 'esquecer tudo' ou ter que 'deletar a linha 1340' quando o cansaço bate, mas na vida real, eu não deletaria nenhum segundo das nossas calls, das nossas risadas ou de cada vez que a gente se apoiou pra não desistir de um problema difícil.")),
    btoa(encodeURIComponent("Sendo bem sincero, do fundo do meu coração: eu gosto muito de estar com você e adoraria ter a chance de ver até onde a gente pode chegar juntos, se você também sentir essa vontade. Eu te admiro pela mulher que você é — a que corre atrás, que não aceita menos que o seu melhor, e que ainda acha tempo pra tornar o simples em especial. Mas não escrevi isso pra te colocar peso ou pressão. Escrevi porque eu precisava que você soubesse que eu enxergo cada detalhezinho do seu brilho.")),
    btoa(encodeURIComponent("Seja como for, eu sigo aqui. Torcendo por você na primeira fileira, orgulhoso da \"menina dos olhos verdes\" que está conquistando o próprio céu.\n\nCom todo o meu carinho,\nFe."))
  ];
  const getLetter = () => _letter.map(p => decodeURIComponent(atob(p)));

  // ── State ────────────────────────────────────────────────────────────────
  let currentQ = 0;
  const TYPE_SPEED = 28;

  // ── Helpers ──────────────────────────────────────────────────────────────
  const print = (text, cls = "text-green-200/70") => {
    const p = document.createElement('p');
    p.className = cls;
    p.textContent = text;
    const container = document.getElementById('challenge-container');
    if (container && output.contains(container)) {
      output.insertBefore(p, container);
    } else {
      output.appendChild(p);
    }
    output.scrollTop = output.scrollHeight;
  };

  const typeWrite = async (text, cls = "text-green-200/70") => {
    const p = document.createElement('p');
    p.className = cls;
    const container = document.getElementById('challenge-container');
    if (container && output.contains(container)) {
      output.insertBefore(p, container);
    } else {
      output.appendChild(p);
    }
    for (let i = 0; i < text.length; i++) {
      p.textContent += text[i];
      output.scrollTop = output.scrollHeight;
      await sleep(TYPE_SPEED);
    }
  };

  const sleep = ms => new Promise(r => setTimeout(r, ms));

  const typeWriteHuman = async (text, cls = "text-green-200/85 leading-relaxed") => {
    const p = document.createElement('p');
    p.className = cls;
    output.appendChild(p);

    const cursor = document.createElement('span');
    cursor.className = "animate-pulse text-green-400 font-bold";
    cursor.textContent = "█";
    p.appendChild(cursor);

    for (let i = 0; i < text.length; i++) {
      cursor.insertAdjacentText('beforebegin', text[i]);
      output.scrollTop = output.scrollHeight;
      let delay = Math.random() * 35 + 18;
      if (['.', '!', '?'].includes(text[i])) delay += 350;
      else if ([',', ';', '…'].includes(text[i])) delay += 180;
      else if (text[i] === '\n') delay += 500;
      await sleep(delay);
    }
    cursor.remove();
  };

  // ── Update challenge UI ──────────────────────────────────────────────────
  const updateChallenge = () => {
    const q = questions[currentQ];
    challengePfx.textContent = `Desafio Nível ${currentQ + 1}:`;
    challengeTxt.textContent = q.text;
    progressTxt.textContent  = `NÍVEL ${currentQ + 1}/${questions.length}`;
    if (btnHint) {
      btnHint.disabled = false;
      btnHint.classList.remove('opacity-30','pointer-events-none');
    }
    input.value    = '';
    input.disabled = false;
    input.focus();
    output.scrollTop = output.scrollHeight;
  };

  // ── Hint button ──────────────────────────────────────────────────────────
  btnHint?.addEventListener('click', e => {
    e.stopPropagation();
    print(`[!] DICA: ${questions[currentQ].hint}`, "text-yellow-400/80 text-xs");
    btnHint.disabled = true;
    btnHint.classList.add('opacity-30','pointer-events-none');
    input.focus();
  });

  // ── Input handler ────────────────────────────────────────────────────────
  input.addEventListener('keydown', async e => {
    if (e.key !== 'Enter') return;
    const value = input.value.trim().toLowerCase();
    if (!value) return;

    input.disabled = true;
    print(`root@system:~$ ${value}`, 'text-green-500/30 text-xs');

    const q = questions[currentQ];
    const correct = q.hashes.includes(hash(value));

    if (correct) {
      await typeWrite("[*] Verificando hash...", "text-yellow-400/80 text-xs");
      await sleep(500);
      await typeWrite("[+] Resposta válida. Acesso parcial concedido.", "text-green-400 font-bold text-xs");

      currentQ++;

      if (currentQ < questions.length) {
        await typeWrite(`[!] Adquirindo nível ${currentQ + 1}/${questions.length}...`, "text-green-500/50 text-xs");
        await sleep(900);
        updateChallenge();

      } else {
        // ── ALL CORRECT ──────────────────────────────────────────────────
        await sleep(300);
        await typeWrite("[+] Todos os níveis concluídos.", "text-green-400 font-bold text-xs");
        await sleep(300);
        await typeWrite("[+] ACESSO TOTAL CONCEDIDO.", "text-green-400 font-bold");
        await sleep(800);

        // Clear terminal
        output.innerHTML = '';
        input.parentElement.style.display = 'none';

        // Separator
        const sep = document.createElement('p');
        sep.className = "text-green-500/20 text-xs tracking-widest mb-6";
        sep.textContent = "─".repeat(48);
        output.appendChild(sep);

        // Type the letter
        const paragraphs = getLetter();
        for (const para of paragraphs) {
          await typeWriteHuman(para, "text-green-100/80 leading-relaxed mb-1");
          // blank line between paragraphs
          const br = document.createElement('div');
          br.className = "h-4";
          output.appendChild(br);
          await sleep(600);
        }

        // Separator
        const sep2 = document.createElement('p');
        sep2.className = "text-green-500/20 text-xs tracking-widest mt-4 mb-8";
        sep2.textContent = "─".repeat(48);
        output.appendChild(sep2);

        // Continue button
        const btnWrap = document.createElement('div');
        btnWrap.className = "text-center opacity-0 transition-opacity duration-700";
        const btn = document.createElement('button');
        btn.textContent = "[ CONTINUAR ]";
        btn.className = "px-8 py-3 border border-green-500/40 text-green-400 bg-green-500/5 font-bold tracking-[0.2em] text-sm rounded hover:bg-green-500/10 hover:border-green-400 hover:shadow-[0_0_20px_rgba(0,255,70,0.15)] transition-all duration-300 cursor-pointer";
        btn.addEventListener('click', () => { window.location.href = getUrl(); });
        btnWrap.appendChild(btn);
        output.appendChild(btnWrap);
        output.scrollTop = output.scrollHeight;
        await sleep(100);
        btnWrap.classList.remove('opacity-0');
        btnWrap.classList.add('opacity-100');
      }

    } else {
      await typeWrite("[-] Acesso negado. Hash inválido.", "text-red-500/80 text-xs");
      input.value    = '';
      input.disabled = false;
      input.focus();
    }
  });

  // Keep focus on click
  window.addEventListener('click', () => { if (!input.disabled) input.focus(); });

  // Init
  updateChallenge();
});
</script>

<style>
  /* Monospace de terminal real */
  @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;700&display=swap');
  
  :root { font-family: 'JetBrains Mono', 'Fira Code', monospace; }

  html, body { background: #000; }

  /* Scrollbar fina estilo terminal */
  #terminal-output::-webkit-scrollbar { width: 4px; }
  #terminal-output::-webkit-scrollbar-track { background: transparent; }
  #terminal-output::-webkit-scrollbar-thumb { background: rgba(0,255,70,0.1); border-radius: 2px; }
  #terminal-output::-webkit-scrollbar-thumb:hover { background: rgba(0,255,70,0.2); }

  /* Cursor customizado */
  * { cursor: crosshair !important; }
  input, textarea { cursor: text !important; }
  button { cursor: pointer !important; }

  /* Glow sutil no texto verde */
  .text-green-400 { text-shadow: 0 0 8px rgba(0,255,70,0.4); }
</style>