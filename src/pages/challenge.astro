---
import Layout from "../layouts/Layout.astro";
---

<Layout title="System Access — Restricted Area">
  <div class="min-h-screen w-full flex flex-col items-center justify-center p-4 sm:p-8 bg-black/90 relative overflow-hidden font-mono text-white selection:bg-[var(--primary)] selection:text-black">
    
    <!-- Efeitos de fundo (scanlines, glow) -->
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,0,0,0)_0%,rgba(0,0,0,0.8)_100%)] z-10"></div>
    <div class="pointer-events-none absolute inset-0 z-20 opacity-10 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.5)_50%)] bg-[length:100%_4px]"></div>

    <div class="z-30 w-full max-w-2xl flex flex-col gap-6">
      
      <!-- Cabeçalho do Terminal -->
      <div class="border border-white/20 bg-black/60 rounded-lg p-1 shadow-[0_0_15px_rgba(0,0,0,0.5)]">
        <div class="flex items-center gap-2 px-3 py-2 border-b border-white/10 bg-white/5 rounded-t-md">
          <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          <span class="ml-2 text-xs font-bold text-white/50 tracking-widest">root@system:~</span>
        </div>
        
        <!-- Corpo do Terminal -->
        <div class="p-6 sm:p-8 text-sm sm:text-base leading-relaxed h-[400px] flex flex-col">
          
          <div id="terminal-output" class="flex-1 overflow-y-auto space-y-3 mb-4 pr-2 custom-scrollbar">
            <p class="text-green-400 font-bold">Iniciando protocolo de segurança avançada...</p>
            <p class="text-white/70">[OK] Camada de ofuscação ativa.</p>
            <p class="text-white/70">[OK] Módulos de detecção passiva rodando em background.</p>
            <br/>
            <p class="text-[var(--primary)] font-bold uppercase tracking-widest">&gt;&gt; ACESSO RESTRITO &lt;&lt;</p>
            <p class="text-white/90">Apenas operadores autorizados podem prosseguir.</p>
            <br/>
            <p class="text-white/60">Para provar seu nível de autorização, resolva o desafio abaixo e insira a resposta correspondente.</p>
            <br/>
            <div id="challenge-container" class="p-4 border border-[var(--primary)]/30 bg-[var(--primary)]/5 rounded text-[var(--primary)] font-bold text-center relative">
              <span id="challenge-prefix" class="text-[var(--primary)]">Desafio:</span> <span id="challenge-text" class="font-normal text-white/90">Qual é o nome do sistema operacional de código aberto cujo mascote é um pinguim chamado Tux?</span><br/>
              <button id="btn-hint" type="button" class="mt-3 text-[10px] sm:text-xs px-3 py-1 bg-black/40 border border-[var(--primary)]/30 text-white/50 hover:text-[var(--primary)] hover:border-[var(--primary)] rounded transition-all uppercase tracking-widest relative z-10">
                [ Mostrar Dica ]
              </button>
            </div>
          </div>

          <!-- Input do usuário -->
          <div class="flex items-center gap-2 mt-auto pt-4 border-t border-white/10 relative">
            <span class="text-[var(--primary)] font-bold" id="prompt-prefix">root@system:~$</span>
            <input 
              type="text" 
              id="flag-input" 
              class="flex-1 bg-transparent border-none outline-none text-white/90 placeholder-white/20 font-mono caret-[var(--primary)]"
              placeholder="Digite a resposta e pressione ENTER..."
              autocomplete="off"
              spellcheck="false"
            />
          </div>

        </div>
      </div>

    </div>
  </div>
</Layout>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('flag-input');
    const output = document.getElementById('terminal-output');
    const promptPrefix = document.getElementById('prompt-prefix');
    const challengePrefix = document.getElementById('challenge-prefix');
    const challengeText = document.getElementById('challenge-text');
    const btnHint = document.getElementById('btn-hint');

    // Desafios para iniciantes
    const questions = [
      {
        text: "Qual é o nome do sistema operacional de código aberto cujo mascote é um pinguim chamado Tux?",
        answers: ["linux"],
        hint: "O nome deste sistema começa com 'L' e termina com 'x'. Foi criado por Linus Torvalds."
      },
      {
        text: "Que linguagem de programação é a base da interatividade na web e roda nativamente nos navegadores?",
        answers: ["javascript", "js"],
        hint: "Sua sigla é frequentemente abreviada como JS."
      },
      {
        text: "Qual é a linguagem de marcação padrão (sigla de 4 letras) usada para estruturar páginas web?",
        answers: ["html"],
        hint: "Começa com H e termina com L."
      },
      {
        text: "Qual é o comando padrão do terminal Linux usado para listar os arquivos de um diretório?",
        answers: ["ls"],
        hint: "São apenas duas letras, uma abreviação da palavra 'list' do inglês."
      }
    ];

    let currentQuestionIndex = 0;

    // Altere a URL de destino aqui!
    const SUCCESS_REDIRECT_URL = "https://juniper-triangle-3f5.notion.site/Para-ela-31cb1baf67dc80bb8436d1dd812d4055?pvs=74";
    const TYPE_SPEED = 30;

    const printToTerminal = (text, className = "text-white/80") => {
      const p = document.createElement('p');
      p.className = className;
      p.textContent = text;
      output.appendChild(p);
      output.scrollTop = output.scrollHeight;
    };

    const typeWriterToTerminal = async (text, className = "text-white/80") => {
      const p = document.createElement('p');
      p.className = className;
      output.appendChild(p);
      
      for (let i = 0; i < text.length; i++) {
        p.textContent += text.charAt(i);
        output.scrollTop = output.scrollHeight;
        await new Promise(r => setTimeout(r, TYPE_SPEED));
      }
    };

    function updateChallengeUI() {
      const q = questions[currentQuestionIndex];
      challengePrefix.textContent = `Desafio Nível ${currentQuestionIndex + 1}: `;
      challengeText.textContent = q.text;
      
      if (btnHint) {
        btnHint.disabled = false;
        btnHint.classList.remove('opacity-30', 'pointer-events-none');
      }
      
      input.value = '';
      input.disabled = false;
      input.focus();

      // Rola a tela para mostrar a pergunta
      const challengeContainer = document.getElementById('challenge-container');
      if (challengeContainer) {
        challengeContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }

    if (btnHint) {
      btnHint.addEventListener('click', (e) => {
        e.stopPropagation(); // Mantém o foco sem pular direto pro input
        const q = questions[currentQuestionIndex];
        printToTerminal(`[!] AJUDA DO SISTEMA: ${q.hint}`, "text-yellow-400 font-bold");
        btnHint.disabled = true;
        btnHint.classList.add('opacity-30', 'pointer-events-none');
        input.focus();
      });
    }

    input.addEventListener('keydown', async (e) => {
      if (e.key === 'Enter') {
        const value = input.value.trim().toLowerCase();
        if (!value) return;

        input.disabled = true;
        printToTerminal(`root@system:~$ ${value}`, 'text-white/50');

        const q = questions[currentQuestionIndex];
        const isCorrect = q.answers.includes(value);

        if (isCorrect) {
          await typeWriterToTerminal("[*] Verificando...", "text-yellow-400 font-bold");
          await new Promise(r => setTimeout(r, 600));
          await typeWriterToTerminal("[+] Resposta válida.", "text-green-400 font-bold");
          
          currentQuestionIndex++;
          
          if (currentQuestionIndex < questions.length) {
            await typeWriterToTerminal(`[!] Adquirindo nível de acesso ${currentQuestionIndex + 1}...`, "text-blue-400 font-bold mt-2");
            setTimeout(() => {
              updateChallengeUI();
            }, 1000);
          } else {
            await typeWriterToTerminal("[+] Acesso Total Concedido.", "text-green-400 font-bold");
            await new Promise(r => setTimeout(r, 1000));
            
            // Limpar o terminal e esconder o input
            output.innerHTML = '';
            const inputContainer = input.parentElement;
            if (inputContainer) inputContainer.style.display = 'none';

            // Mensagem
            const letterParagraphs = [
              "Bru, aproveitando que a gente tem esse espaço e estamos conversando com calma... tem algo que já faz um tempo que eu queria te dizer. Você sabe o quanto eu valorizo a nossa parceria e a liberdade incrível que a gente tem para falar sobre tudo. E é exatamente por essa confiança que eu cheguei à conclusão de que não queria esconder mais nada de você.",
              "Lembra quando eu te falei que eu estava gostando de alguém? Pois é... eu estava falando de você esse tempo todo. Aos poucos eu fui percebendo que, para mim, aquilo que sempre foi nossa amizade começou a se transformar em algo muito maior. Acabou sendo impossível não sentir isso, porque eu admiro demais a pessoa que você é, a sua essência e a forma tão autêntica como você leva a vida.",
              "Como eu consigo me expressar muito melhor escrevendo do que falando cara a cara, deixei meus sentimentos em um link que você vai acessar logo logo, quando o botão de continuar aparecer. Leia no seu ritmo, quando estiver em paz. Não existe pressa nenhuma para você ler e, principalmente, não quero que sinta a obrigação de me dar uma resposta logo de cara, tá? Meu único objetivo hoje era que você soubesse de verdade.",
              "E olha, de todo o meu coração: fica tranquila. A minha maior prioridade sempre vai ser a gente continuar numa boa. Jamais iria querer que você se sentisse cobrada ou pressionada. Quando (e se) você quiser conversar a respeito de tudo, estarei aqui para ouvir. Se só precisar de um espaço e um tempo para processar, eu te entendo 100%. Tudo no seu tempo."
            ];

            // Digitar a carta
            for (const paragraph of letterParagraphs) {
              const p = document.createElement('p');
              p.className = "text-white/90 mb-5 leading-relaxed tracking-wide text-sm sm:text-base";
              output.appendChild(p);
              
              const cursor = document.createElement('span');
              cursor.className = "ml-1 animate-pulse font-bold text-[var(--primary)] text-sm";
              cursor.textContent = "█";
              p.appendChild(cursor);

              for (let i = 0; i < paragraph.length; i++) {
                cursor.insertAdjacentText('beforebegin', paragraph.charAt(i));
                output.scrollTop = output.scrollHeight;
                
                // Variar a velocidade pra parecer humano
                let delay = Math.random() * 30 + 20; // 20 a 50ms
                if (['.', ',', '?', '!'].includes(paragraph.charAt(i))) {
                  delay += 300; // pausa nas vírgulas e pontos
                }
                
                await new Promise(r => setTimeout(r, delay));
              }
              
              cursor.remove(); // remove o cursor ao final do parágrafo
              await new Promise(r => setTimeout(r, 800)); // pausa antes do proximo paragrafo
            }

            // Botão Continuar
            const btnContainer = document.createElement('div');
            btnContainer.className = "mt-8 mb-4 text-center transition-opacity duration-1000 opacity-0 relative z-50 pointer-events-auto";
            const btnNext = document.createElement('button');
            btnNext.textContent = "[ CONTINUAR ]";
            btnNext.className = "px-6 py-3 border border-[var(--primary)] text-[var(--primary)] bg-[var(--primary)]/10 font-bold tracking-widest rounded hover:bg-[var(--primary)] hover:text-black transition-all duration-300 cursor-pointer";
            
            btnNext.addEventListener('click', () => {
              window.location.href = SUCCESS_REDIRECT_URL;
            });

            btnContainer.appendChild(btnNext);
            output.appendChild(btnContainer);
            output.scrollTop = output.scrollHeight;

            // Fade in do botão
            setTimeout(() => {
              btnContainer.classList.remove('opacity-0');
              btnContainer.classList.add('opacity-100');
            }, 100);
          }

        } else {
          await typeWriterToTerminal("[-] Acesso negado. Resposta incorreta.", "text-red-500 font-bold");
          input.value = '';
          input.disabled = false;
          input.focus();
        }
      }
    });

    window.addEventListener('click', () => {
      if(!input.disabled) input.focus();
    });

    // Iniciar
    updateChallengeUI();
  });
</script>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
  }
</style>

<style is:global>
  /* Remove o piscar da classe crt-flicker e restaura ponteiros */
  .crt-flicker {
    animation: none !important;
    opacity: 1 !important;
  }
  
  /* Restaura o cursor padrão apenas nesta aba para melhor experiência no terminal */
  *, html, body, a, button, input, textarea {
    cursor: auto !important;
  }
  input, textarea {
    cursor: text !important;
  }
  #custom-cursor {
    display: none !important;
  }
</style>
